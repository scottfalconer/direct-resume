{
  "manifest_version": 3,
  "name": "Direct Resume",
  "version": "0.1.0",
  "description": "Directly resume local AI coding sessions from supported work-object pages.",
  "host_permissions": [
    "https://www.drupal.org/*",
    "http://127.0.0.1:38551/*",
    "http://localhost:38551/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.drupal.org/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Direct Resume"
  }
}
